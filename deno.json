{
  "unstable": [
    "kv"
  ],
  "workspace": [
    "./apps/web",
    "./apps/ops",
    "./packages/ui",
    "./packages/utils",
    "./packages/tokens",
    "./packages/foundations",
    "./packages/data",
    "./packages/services",
    "./packages/icons",
    "./packages/lint-plugins"
  ],
  "tasks": {
    "autofix": "deno fmt && deno lint",
    "test": "deno test --unstable-kv",
    "precommit": "deno task autofix && deno check -q && ./scripts/run-changed-tests.sh",
    "serve:web": "cd apps/web && deno task dev",
    "serve:ops": "cd apps/ops && deno task dev",
    "build": "cd apps/web && deno task build",
    "start": "cd apps/web && deno task start",
    "update": "deno run -A -r jsr:@fresh/update .",
    "source-guard": "deno fmt --check --fail-fast --ignore='**/*.md' . && deno lint . && deno check -q",
    "runtime-guard": "deno task test && cd apps/web && deno task build",
    "validate-mermaid": "./scripts/validate-mermaid.sh",
    "console:local": "CONSOLE_TARGET=local deno repl --unstable-kv --allow-env --allow-net --allow-read --allow-write --eval-file=packages/data/tools/console.ts",
    "console:remote": "CONSOLE_TARGET=remote deno repl --unstable-kv --allow-env --allow-net --allow-read --eval-file=packages/data/tools/console.ts"
  },
  "fmt": {
    "semiColons": false,
    "useTabs": false,
    "lineWidth": 80,
    "indentWidth": 2,
    "singleQuote": true,
    "proseWrap": "preserve",
    "trailingCommas": "never"
  },
  "lint": {
    "plugins": [
      "jsr:@narumincho/type-lint",
      "./packages/lint-plugins/mod.ts"
    ],
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "imports": {
    "@/": "./",
    "@std/assert": "jsr:@std/assert@^1.0.16",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "@std/uuid": "jsr:@std/uuid@^1.1.0",
    "fresh": "jsr:@fresh/core@^2.2.0",
    "preact": "npm:preact@^10.27.2",
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "vite": "npm:vite@^7.1.3",
    "tailwind-merge": "npm:tailwind-merge@^3.5.0",
    "tailwindcss": "npm:tailwindcss@^4.1.10",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "verbatimModuleSyntax": true,
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns",
      "deno.unstable"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ]
  }
}
